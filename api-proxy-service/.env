# API中转调度服务配置

# 服务端口
PORT=3001

# 环境
NODE_ENV=development

# JWT密钥
JWT_SECRET=nanaz_jwt_secret_key_2024

# 旷视 Face++ 配置（未配置时使用mock）
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_REGION=api-cn.faceplusplus.com

# 智谱 GLM-4 Flash 配置（未配置时使用mock）
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 豆包 Lite 配置（未配置时使用mock）
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-lite-4k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 限流配置
RATE_LIMIT_PER_USER_PER_DAY=10
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# 缓存配置
CACHE_DURATION_SECONDS=3600

# 数据库配置
DATABASE_PATH=./data/nanaz.db

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/api-proxy.log

# 隐私合规配置
FACE_DATA_EXPIRE_DAYS=7
API_LOG_RETAIN_DAYS=1095