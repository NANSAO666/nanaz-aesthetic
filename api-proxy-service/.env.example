# API中转调度服务配置

# 服务端口
PORT=3001

# 环境（development/production）
NODE_ENV=development

# JWT密钥（用于验证前端请求）
JWT_SECRET=your_jwt_secret_key_here

# ========== 旷视 Face++ 配置 ==========
FACEPP_API_KEY=your_facepp_api_key
FACEPP_API_SECRET=your_facepp_api_secret
FACEPP_REGION=api-cn.faceplusplus.com

# ========== 智谱 GLM-4 Flash 配置 ==========
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ========== 豆包 Lite 配置 ==========
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_MODEL=doubao-lite-4k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ========== 限流配置 ==========
# 单用户每日最大生成报告次数
RATE_LIMIT_PER_USER_PER_DAY=10

# 全局每分钟最大请求次数
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# ========== 缓存配置 ==========
# 报告缓存时间（秒），相同人脸不重复生成
CACHE_DURATION_SECONDS=3600

# ========== 数据库配置 ==========
DATABASE_PATH=./data/nanaz.db

# ========== 日志配置 ==========
LOG_LEVEL=info
LOG_FILE=./logs/api-proxy.log

# ========== 隐私合规配置 ==========
# 人脸数据自动删除天数
FACE_DATA_EXPIRE_DAYS=7

# API日志保留天数（监管要求至少3年）
API_LOG_RETAIN_DAYS=1095